{
  "mcpServers": {
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://{user}:{password}@{host}:{port}/{database}" 
      ]
    },
    "markdown2pdf": {
      "command": "npx",
      "args": ["-y", "markdown2pdf-mcp@latest"],
      "env": {
        "M2P_OUTPUT_DIR": "./reports"
      }
    }
  }
}

